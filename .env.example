#  ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# TL;DR  -->  declare the short repo-owned env contract for SynaWeave CE
#
# - Later Extension Points:
#   --> add values only when a real runtime boundary or adapter needs them
#
# - Role:
#   --> keep the canonical config surface short generic and provider-swappable where possible
#   --> let adapters and deploy manifests map provider-specific aliases when required
#
# - Exports:
#   --> browser-safe app values
#   --> server-only runtime values
#   --> provider-edge values for deploy and adapters
#
# - Consumed By:
#   --> local operators provisioning .env files for repo-owned runtime proof
#   --> app-local loaders deploy manifests and adapter configuration at provider edges
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# product
SW_NAME=synaweave-ce
SW_ENV=local
SW_MODE=open_core
SW_REGION=us-east1

# browser-safe app values
APP_URL=http://127.0.0.1:3000
API_URL=http://127.0.0.1:8000
AUTH_URL=http://127.0.0.1:8000
AUTH_LOCAL_ONLY=1
APP_AUTH_MODES=oidc,magic_link,otp,passkey
APP_AUTH_MAP_JSON={"google":"oidc","github":"oidc","email":"magic_link","phone":"otp","device":"passkey"}

# api runtime
API_HOST=127.0.0.1
API_PORT=8000
API_BASE_URL=http://127.0.0.1:8000
JOB_INGEST_NAME=sw-ingest

# core data contract
DB_KIND=pg
DB_URL=postgresql://local-example-db-url
DB_POOL_URL=postgresql://local-example-db-pool-url
DB_SSL=prefer
VEC_KIND=pgvector
OBJ_KIND=s3
OBJ_BUCKET=sw-assets-local
CACHE_KIND=memory
QUEUE_KIND=local
GRAPH_KIND=neo4j
GRAPH_URL=bolt://local.example.invalid:7687
GRAPH_USER=local-example-graph-user
GRAPH_PASS=local-placeholder-graph-pass

# auth contract
AUTH_KIND=oidc
AUTH_AUD=synaweave-local
AUTH_JWKS_URL=https://local.example.invalid/.well-known/jwks.json
AUTH_LINK_TTL_SEC=900
AUTH_OTP_TTL_SEC=300
AUTH_QR_ISSUER=SynaWeave
EMAIL_FROM=noreply@example.com

# oauth / oidc providers
OIDC_GOOGLE_ID=local-example-google-id
OIDC_GOOGLE_SECRET=local-placeholder-google-secret
OIDC_GH_ID=local-example-gh-id
OIDC_GH_SECRET=local-placeholder-gh-secret
OIDC_LINKEDIN_ID=local-example-linkedin-id
OIDC_LINKEDIN_SECRET=local-placeholder-linkedin-secret
OIDC_APPLE_ID=local-example-apple-id
OIDC_APPLE_SECRET=local-placeholder-apple-secret

# tracing and metrics
TRACE_ON=0
TRACE_OTLP_URL=http://127.0.0.1:4318
TRACE_OTLP_HEADERS=Authorization=Bearer local-placeholder-trace-token
TRACE_BATCH_MS=250
TRACE_SVC=sw-api
METRIC_PORT=8000
LOG_LEVEL=INFO

# gcp edge and deploy
GCP_PROJECT_ID=local-example-gcp-project
GCP_REGION=us-east1
GCP_SA_EMAIL=local-example-sa@local.example.invalid
CR_API_NAME=sw-api
CR_INGEST_NAME=sw-ingest
GKE_CLUSTER=local-example-gke-cluster
GKE_REGION=us-east1

# supabase edge values
SB_URL=https://local.example.invalid
SB_ANON_KEY=local-placeholder-sb-anon-key
SB_SVC_KEY=local-placeholder-sb-svc-key
SB_DB_URL=postgresql://local-example-sb-db-url

# backblaze b2 edge values
B2_KEY_ID=local-example-b2-key-id
B2_APP_KEY=local-placeholder-b2-app-key
B2_BUCKET=sw-assets-local
B2_REGION=us-west-000
B2_ENDPOINT=https://s3.us-west-000.backblazeb2.com

# zuplo edge values
ZP_URL=https://local.example.invalid
ZP_KEY=local-placeholder-zp-key

# neo4j edge values
N4J_URI=bolt://local.example.invalid:7687
N4J_USER=local-example-n4j-user
N4J_PASS=local-placeholder-n4j-pass
N4J_DB=neo4j

# ai eval and experiment services
EVAL_KIND=lf
EVAL_URL=http://127.0.0.1:3030
EVAL_PK=local-placeholder-eval-pk
EVAL_SK=local-placeholder-eval-sk
EXP_KIND=mlflow
EXP_URL=http://127.0.0.1:5000
EXP_NAME=sw-runtime-local
LF_URL=http://127.0.0.1:3030
LF_PK=local-placeholder-lf-pk
LF_SK=local-placeholder-lf-sk
MLF_URL=http://127.0.0.1:5000
MLF_S3_URL=https://local.example.invalid
MF_PROFILE=local
MF_DATASTORE=local

# model providers
MODEL_KIND=local
MODEL_URL=http://127.0.0.1:11434
EMB_KIND=local
EMB_URL=http://127.0.0.1:11434

# github and docs
GH_OWNER=local-example-gh-owner
GH_REPO=local-example-gh-repo
GH_PAGES_URL=https://local.example.invalid

# google workspace
GW_DOMAIN=local.example.invalid
GW_ADMIN=local-example-admin@local.example.invalid
SMTP_HOST=smtp.local.example.invalid
SMTP_PORT=587
SMTP_USER=local-example-smtp-user
SMTP_PASS=local-placeholder-smtp-pass

# note
# if a framework or sdk hard-requires provider-specific aliases such as NEXT_PUBLIC_* or SUPABASE_* names,
# map them in the app-local loader or deploy manifest instead of letting those aliases become the main repo language.
