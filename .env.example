#  ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# TL;DR  -->  declare the sample runtime environment contract for browser-safe server-only and telemetry settings
#
# - Later Extension Points:
#   --> add more sample variables only when shared runtime boundaries or providers expand
#
# - Role:
#   --> document the repo-owned example environment surface for local setup and review
#   --> keep browser-safe and server-only configuration examples visible at the runtime boundary
#
# - Exports:
#   --> `PUBLIC_*` browser-safe variables
#   --> server runtime variables
#   --> telemetry and optional service variables
#
# - Consumed By:
#   --> developers operators and repo docs that describe local runtime configuration
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# one intent: browser-safe values
PUBLIC_API_BASE_URL=https://api.local.example
PUBLIC_SUPABASE_URL=https://project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=example-publishable-anon-key
PUBLIC_AUTH_BASE_URL=https://auth.local.example
PUBLIC_AUTH_REDIRECT_BASE_URL=https://app.local.example
PUBLIC_AUTH_METHODS=federated_oidc,email_link,passkey
PUBLIC_AUTH_CONN_MAP_JSON={"primary-google":"federated_oidc","primary-apple":"federated_oidc","primary-linkedin":"federated_oidc","primary-github":"federated_oidc","email-link":"email_link","device-passkey":"passkey"}

# one intent: server-only values
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=example-service-role-key
DATABASE_URL=example-database-url-set-in-local-env
OBJECT_STORAGE_BUCKET=assets
AUTH_ISSUER_URL=https://issuer.local.example
AUTH_AUDIENCE=synaweave-local
AUTH_JWKS_URL=https://issuer.local.example/.well-known/jwks.json
AUTH_SERVICE_ROLE_ENV=SUPABASE_SERVICE_ROLE_KEY
AUTH_CONN_MAP_JSON={"primary-google":"google","primary-apple":"apple","primary-linkedin":"linkedin","primary-github":"github","email-link":"magic-link","device-passkey":"passkey"}

# one intent: telemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <redacted>
OTEL_SERVICE_NAME=synakweave-runtime

# one intent: optional model and graph services
GRAPH_URL=http://localhost:8000
EMBEDDING_PROVIDER=local
MODEL_PROVIDER=local
